{
  "name": "piano-tutor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Free, browser-based piano tutorial player for kids.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build:library": "node scripts/gen-songs.mjs && node scripts/build-library.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "pitchy": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.8"
  }
}
